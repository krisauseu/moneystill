# PocketBase Configuration
# The public URL of your PocketBase instance (e.g., https://pb.yourdomain.com)
VITE_POCKETBASE_URL=http://your-pocketbase-url:8090

# Stripe Configuration (required for subscription features)
# Your Stripe Secret Key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_replace_with_your_actual_key

# The Stripe Price ID for the subscription plan
STRIPE_PRICE_ID=price_replace_with_your_actual_price_id

# Frontend URL
# The public URL of your frontend application (used for Stripe redirects)
FRONTEND_URL=https://app.yourdomain.com
